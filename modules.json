{
    "version": "0.1",
    "modules": [
        {
            "name": "Default",
            "category": "Default",
            "description": "Default attributes for all devcontainers",
            "devcontainer": {
                "runArgs": [],
                "features": {},
                "extensions": [],
                "settings": {
                    "workbench.colorTheme": "Default Dark Modern",
                    "workbench.sideBar.location": "right"
                }
            },
            "scripts": [],
            "environment": []
        },
        {
            "name": "Intel Arc GPU",
            "category": "Hardware",
            "description": "Attaching an Intel Arc GPU & installing necessary drivers",
            "devcontainer": {
                "runArgs": [
                    "--device=/dev/dri:/dev/dri",
                    "--ipc=host",
                    "--shm-size=<RAM>"
                ],
                "features": {},
                "extensions": [],
                "settings": {}
            },
            "scripts": [
                "install_arc_gpu.sh"
            ],
            "environment": [
                "SYCL_DEVICE_FILTER=level_zero:gpu",
                "ZES_ENABLE_SYSMAN=0",
                "SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1"
            ]
        },
        {
            "name": "Jupyter Notebook",
            "category": "Languages",
            "description": "Jupyter notebooks via pyenv with pip and venv",
            "devcontainer": {
                "runArgs": [],
                "features": {
                    "ghcr.io/devcontainers/features/python:1": {
                        "version": "3.12"
                    }
                },
                "extensions": [
                    "ms-toolsai.jupyter",
                    "ms-toolsai.vscode-jupyter-cell-tags",
                    "ms-toolsai.jupyter-keymap",
                    "ms-toolsai.jupyter-renderers",
                    "ms-toolsai.vscode-jupyter-slideshow",
                    "ms-python.vscode-pylance",
                    "ms-python.python",
                    "ms-python.debugpy",
                    "ms-toolsai.vscode-jupyter-powertoys"
                ],
                "settings": {
                    "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
                }
            },
            "scripts": [
                "install_jupyter.sh"
            ],
            "environment": []
        },
        {
            "name": "CLI Dev Apps",
            "category": "Tools",
            "description": "Applications for developing via a command line interface",
            "devcontainer": {
                "runArgs": [],
                "features": {
                    "ghcr.io/devcontainers-extra/features/tmux-apt-get:1": {},
                    "ghcr.io/duduribeiro/devcontainer-features/neovim:1": {
                        "version": "stable"
                    }
                },
                "extensions": [],
                "settings": {}
            },
            "scripts": [
                "install_nvim.sh",
                "install_tmux.sh"
            ],
            "environment": []
        },
        {
            "name": "Python",
            "category": "Languages",
            "description": "Python 3 via pyenv with pip and venv",
            "devcontainer": {
                "runArgs": [],
                "features": {
                    "ghcr.io/devcontainers/features/python:1": {
                        "version": "3.12"
                    }
                },
                "extensions": [
                    "ms-python.vscode-pylance",
                    "ms-python.python"
                ],
                "settings": {
                    "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
                }
            },
            "scripts": [
                "install_python.sh"
            ],
            "environment": []
        }
    ]
}
